# Database (see docker-compose.yml)
DATABASE_URL="postgresql://taskflow:dev_password_change_me@localhost:5433/taskflow?schema=public"
# Used only by `npm run test:integration` — same Postgres instance, disposable DB
DATABASE_URL_TEST="postgresql://taskflow:dev_password_change_me@localhost:5433/taskflow_test?schema=public"
POSTGRES_PASSWORD="dev_password_change_me"

# Auth
JWT_ACCESS_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"

NODE_ENV="development"

# Public site URL (used for OpenGraph/sitemap/robots and OAuth redirect URIs)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# OAuth (optional — the app works fine without these, the buttons will just
# error until configured; see README for how to obtain these)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
